<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PrivateVaultApp.VaultPage"
             Title="Private Vault">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Private Vault"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="Store your personal secrets safely on your device."
                   FontSize="14"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Border Stroke="LightGray"
                    StrokeThickness="1"
                    Padding="15"
                    StrokeShape="RoundRectangle 12">

                <VerticalStackLayout Spacing="12">

                    <Entry x:Name="titleEntry"
                           Placeholder="Enter title" />

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">

                        <Entry x:Name="secretEntry"
                               Placeholder="Enter secret"
                               IsPassword="True"
                               Grid.Column="0" />

                        <Button Text="Show"
                                Grid.Column="1"
                                Clicked="OnTogglePassword" />
                    </Grid>

                    <Button Text="Add to Vault"
                            Clicked="OnAddClicked" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Saved Items"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,10,0,0" />

            <CollectionView x:Name="vaultList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Stroke="LightGray"
                                StrokeThickness="1"
                                Padding="12"
                                Margin="0,5"
                                StrokeShape="RoundRectangle 10">

                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Title}"
                                       FontSize="18"
                                       FontAttributes="Bold" />

                                <Label Text="{Binding SecretText}"
                                       FontSize="14" />

                                <Button Text="Delete"
                                        Clicked="OnDeleteClicked" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>